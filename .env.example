# ============================================
# CodeThinker — Environment Variables
# ============================================
# Copy this file to .env.local and fill in your keys
# cp .env.example .env.local

# ---- Required ----

# Groq (primary AI provider — free tier available)
# Get your key at https://console.groq.com
GROQ_API_KEY=

# ---- Optional: Tool Use ----

# Tavily (web search tool — free: 1000 req/month)
# Get your key at https://tavily.com
TAVILY_API_KEY=

# ---- Optional: Chat Persistence ----

# Supabase (for saving chat sessions)
# Get your keys at https://supabase.com
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# ---- Optional: Additional Providers ----

# OpenAI (users can also enter their key in the UI Settings modal)
OPENAI_API_KEY=

# DeepSeek (emergency fallback)
# Get your key at https://platform.deepseek.com
DEEPSEEK_API_KEY=
